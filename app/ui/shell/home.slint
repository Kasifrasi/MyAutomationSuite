import { Palette, AboutSlint } from "std-widgets.slint";

component MenuCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <image> icon;
    callback clicked();

    border-radius: 12px;
    background: Palette.control-background;
    border-width: 1px;
    border-color: ta.has-hover ? Palette.accent-background : Palette.border;
    height: 140px;

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
        mouse-cursor: pointer;
    }

    VerticalLayout {
        padding: 24px;
        spacing: 10px;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            Image {
                source: root.icon;
                width: 32px;
                height: 32px;
                colorize: Palette.accent-background;
            }
        }

        Text {
            text: root.title;
            font-size: 16px;
            font-weight: 700;
            color: Palette.foreground;
            horizontal-alignment: center;
        }

        Text {
            text: root.description;
            font-size: 13px;
            color: Palette.foreground;
            opacity: 0.6;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

export component HomePage inherits VerticalLayout {
    callback navigate(string);
    in-out property <bool> color-a: true;
    in-out property <bool> color-b: false;
    in-out property <bool> color-c: false;

    spacing: 20px;

    Rectangle {
        vertical-stretch: 1;
    }

    // Titel
    VerticalLayout {
        spacing: 4px;
        Text {
            text: "Automation-Tool";
            font-size: 28px;
            font-weight: 800;
            color: Palette.foreground;
            horizontal-alignment: center;
        }

        Text {
            text: "Werkzeug auswählen";
            font-size: 14px;
            color: Palette.foreground;
            opacity: 0.5;
            horizontal-alignment: center;
        }
    }

    // Kacheln (2×2-Raster) mit Farbwechsel-Rahmen
    HorizontalLayout {
        alignment: center;
        Rectangle {
            horizontal-stretch: 0;
            border-radius: 20px;
            border-width: 2px;
            border-color: color-a ? #6366f1 : color-b ? #ec4899 : color-c ? #14b8a6 : #f59e0b;
            background: color-a ? #6366f110 : color-b ? #ec489910 : color-c ? #14b8a610 : #f59e0b10;
            animate border-color {
                duration: 3s;
                easing: ease-in-out;
            }
            animate background {
                duration: 3s;
                easing: ease-in-out;
            }

            Timer {
                interval: 3s;
                running: true;
                triggered => {
                    if (color-a) {
                        color-a = false;
                        color-b = true;
                    } else if (color-b) {
                        color-b = false;
                        color-c = true;
                    } else if (color-c) {
                        color-c = false;
                        color-a = true;
                    }
                }
            }

            VerticalLayout {
                padding: 20px;
                spacing: 16px;

                HorizontalLayout {
                    spacing: 16px;
                    alignment: center;

                    MenuCard {
                        title: "Budget zu FB";
                        description: "Budgets in Finanzberichte konvertieren";
                        icon: @image-url("../shared/icons/xlsx.svg");
                        width: 260px;
                        clicked => {
                            root.navigate("budget");
                        }
                    }

                    MenuCard {
                        title: "FB-Generator";
                        description: "Finanzberichtsvorlagen erstellen";
                        icon: @image-url("../shared/icons/xlsx.svg");
                        width: 260px;
                        clicked => {
                            root.navigate("fb");
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: center;

                    MenuCard {
                        title: "Budget zu Prüfvorlage";
                        description: "Budgets scannen & Prüfvorlagen erstellen";
                        icon: @image-url("../shared/icons/xlsx.svg");
                        width: 260px;
                        clicked => {
                            root.navigate("vorpruefung");
                        }
                    }

                    MenuCard {
                        title: "Ordner erstellen";
                        description: "Erstellt Ordner mit Prüfvorlage";
                        icon: @image-url("../shared/icons/folder.svg");
                        width: 260px;
                        clicked => {
                            root.navigate("folder");
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        vertical-stretch: 1;
    }

    HorizontalLayout {
        alignment: end;
        AboutSlint {
            width: 125px;
        }
    }
}
