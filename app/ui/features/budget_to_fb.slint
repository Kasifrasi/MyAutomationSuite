import {
    Button,
    CheckBox,
    LineEdit,
    GridBox,
    Palette,
    StandardTableView,
    ScrollView,
} from "std-widgets.slint";
import {
    Card,
    StatusBanner,
    SettingCheckBox,
    CategorySpinBox,
    PasswordField,
} from "../shared/components.slint";
import { BudgetState } from "../shared/state.slint";

export component BudgetPage inherits VerticalLayout {
    spacing: 10px;
    // Wir lassen das äußere Layout den Platz verwalten.

    // --- 1. FIXED HEADER (Status & Pfade) ---
    VerticalLayout {
        spacing: 10px;

        if BudgetState.status-type != "idle": StatusBanner {
            status-type: BudgetState.status-type;
            status-message: BudgetState.status-message;
            dismiss => {
                BudgetState.dismiss-status();
            }
        }

        HorizontalLayout {
            spacing: 16px;
            // Quelle
            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: 8px;
                LineEdit {
                    text <=> BudgetState.src-folder;
                    read-only: true;
                    placeholder-text: "* Quellordner...";
                    horizontal-stretch: 1;
                }

                Button {
                    text: "Quelle...";
                    clicked => {
                        BudgetState.select-src();
                    }
                }
            }
            // Ausgabe
            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: 8px;
                padding-right: 12px;
                LineEdit {
                    text <=> BudgetState.out-folder;
                    read-only: true;
                    placeholder-text: "* Ausgabeordner...";
                    horizontal-stretch: 1;
                }

                Button {
                    text: "Ausgabe...";
                    clicked => {
                        BudgetState.select-out();
                    }
                }
            }
        }
    }

    // --- 2. SCROLLABLE CONTENT (Settings & Tabelle) ---
    // Dieses Element saugt den restlichen Platz auf und hält den Footer unten.
    ScrollView {
        vertical-stretch: 1;

        scroll-layout := VerticalLayout {
            spacing: 12px;
            padding-right: 12px; // Platz für die Scrollbar

            // Erweiterte Einstellungen
            if BudgetState.show-settings: Card {
                title: "Erweiterte Einstellungen";
                VerticalLayout {
                    spacing: 12px;

                    // Dateiname / Muster
                    HorizontalLayout {
                        spacing: 16px;
                        alignment: start;
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "* Dateinamens-Muster";
                                font-size: 13px;
                                font-weight: 600;
                                opacity: 0.8;
                            }

                            LineEdit {
                                text <=> BudgetState.name;
                                placeholder-text: "* z.B. {pn}_{la}_{version}_FB.xlsx";
                                width: 280px;
                                edited => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            Text {
                                text: "💡 Platzhalter:\n{pn} = Projektnummer\n{la} = Sprache\n{version} = Version aus Budget\n{i} = Duplikate-Zähler";
                                font-size: 12px;
                                opacity: 0.7;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Layout & Struktur
                    GridBox {
                        spacing: 10px;
                        Row {
                            SettingCheckBox {
                                text: "Spalten Q:V ausblenden";
                                value <=> BudgetState.hide-columns;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            HorizontalLayout {
                                spacing: 16px;
                                alignment: start;
                                Text {
                                    text: "Pufferzeilen in dynamischen Kategorien";
                                    font-size: 13px;
                                    opacity: 0.8;
                                    vertical-alignment: center;
                                }

                                CategorySpinBox {
                                    value <=> BudgetState.empty-rows;
                                    minimum: 0;
                                    maximum: 20;
                                    max-width: 120px;
                                    changed => {
                                        BudgetState.save-settings();
                                    }
                                }
                            }
                        }
                    }

                    // Sichtbarkeit & Schutz
                    GridBox {
                        spacing: 10px;
                        Row {
                            SettingCheckBox {
                                text: "Blattschutz";
                                value <=> BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Mappenschutz";
                                value <=> BudgetState.protect-workbook;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }
                    }

                    // Passwörter
                    HorizontalLayout {
                        spacing: 8px;
                        PasswordField {
                            label: "Blatt-Passwort";
                            password <=> BudgetState.sheet-password;
                            is-enabled: BudgetState.protect-sheet;
                            changed => {
                                BudgetState.save-settings();
                            }
                        }

                        PasswordField {
                            label: "Mappen-Passwort";
                            password <=> BudgetState.workbook-password;
                            is-enabled: BudgetState.protect-workbook;
                            changed => {
                                BudgetState.save-settings();
                            }
                        }
                    }

                    // Berechtigungen
                    Text {
                        text: "Erlaubte Aktionen bei Blattschutz";
                        font-size: 13px;
                        font-weight: 600;
                        opacity: BudgetState.protect-sheet ? 0.6 : 0.3;
                    }

                    GridBox {
                        spacing: 2px;
                        Row {
                            SettingCheckBox {
                                text: "Gesperrte Zellen wählen";
                                value <=> BudgetState.sheet-permissions.select-locked-cells;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Spalten löschen";
                                value <=> BudgetState.sheet-permissions.delete-columns;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Freie Zellen wählen";
                                value <=> BudgetState.sheet-permissions.select-unlocked-cells;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Zeilen löschen";
                                value <=> BudgetState.sheet-permissions.delete-rows;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Zellen formatieren";
                                value <=> BudgetState.sheet-permissions.format-cells;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Sortieren";
                                value <=> BudgetState.sheet-permissions.sort;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Spalten formatieren";
                                value <=> BudgetState.sheet-permissions.format-columns;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Autofilter";
                                value <=> BudgetState.sheet-permissions.auto-filter;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Zeilen formatieren";
                                value <=> BudgetState.sheet-permissions.format-rows;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Pivot-Tabellen";
                                value <=> BudgetState.sheet-permissions.pivot-tables;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Spalten einfügen";
                                value <=> BudgetState.sheet-permissions.insert-columns;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Objekte bearbeiten";
                                value <=> BudgetState.sheet-permissions.edit-objects;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Zeilen einfügen";
                                value <=> BudgetState.sheet-permissions.insert-rows;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Szenarien";
                                value <=> BudgetState.sheet-permissions.edit-scenarios;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }

                        Row {
                            SettingCheckBox {
                                text: "Links einfügen";
                                value <=> BudgetState.sheet-permissions.insert-hyperlinks;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }

                            SettingCheckBox {
                                text: "Inhalte schützen";
                                value <=> BudgetState.sheet-permissions.contents;
                                is-enabled: BudgetState.protect-sheet;
                                changed => {
                                    BudgetState.save-settings();
                                }
                            }
                        }
                    }
                }
            }

            // Ergebnistabelle
            Card {
                title: "Ergebnisse";
                min-height: 250px; // Wichtig, damit die Tabelle im Scroll-View sichtbar bleibt
                StandardTableView {
                    columns: BudgetState.table-columns;
                    rows: BudgetState.table-data;
                }
            }
        }
    }

    // --- 3. FIXED FOOTER (Aktionen) ---
    HorizontalLayout {
        padding-top: 5px;
        spacing: 12px;

        Button {
            text: BudgetState.show-settings ? "Einstellungen ▲" : "Einstellungen ▼";
            clicked => {
                BudgetState.toggle-settings();
            }
        }

        Button {
            text: "Zurücksetzen";
            clicked => {
                BudgetState.do-reset();
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        } // Spacer

        Button {
            text: "Ansicht → CSV";
            clicked => {
                BudgetState.do-export-txt();
            }
        }

        Button {
            text: "Ansicht → Excel";
            clicked => {
                BudgetState.do-export-excel();
            }
        }

        Button {
            text: BudgetState.status-type == "pending" ? "Scannt..." : "Scan starten (F5)";
            primary: true;
            enabled: BudgetState.src-folder != "" && BudgetState.out-folder != "" && BudgetState.name != "" && BudgetState.status-type != "pending";
            clicked => {
                BudgetState.scan();
            }
            width: 200px;
        }
    }
}
